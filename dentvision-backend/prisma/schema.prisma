generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───

enum UserRole {
  OWNER
  DOCTOR
  ASSISTANT
  ADMIN
  CASHIER
  LAB
  MANAGER
  STUDENT
  SUPERADMIN
}

enum ClinicPlan {
  DEMO
  STANDARD
  PRO
  ENTERPRISE
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum InvoiceStatus {
  PAID
  UNPAID
  PARTIAL
  REFUND
  PENDING
  OVERDUE
}

enum ImageType {
  PHOTO
  X_RAY
  CBCT
  DICOM
  SCAN
}

// ─── USER SYSTEM ───

model User {
  id        String   @id @default("")
  email     String   @unique
  password  String
  firstName String
  lastName  String
  avatar    String?
  phone     String?
  spec      String?
  profileMeta Json?
  role      UserRole @default(DOCTOR)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships  ClinicMember[]
  aiSessions   AISession[]
  notifications Notification[]
  aiActions    AIAction[]
  aiAlerts     AIAlert[]
  orders       Order[]
  enrollments  SchoolEnrollment[]

  @@map("users")
}

model Clinic {
  id      String      @id @default("")
  name    String
  city    String?
  address String?
  phone   String?
  logo    String?
  plan    ClinicPlan  @default(DEMO)
  /// Platform ops: false = suspended / blocked from service.
  active  Boolean     @default(true)
  /// Per-clinic CRM settings: hours, reminders, currency, etc.
  settings Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members       ClinicMember[]
  invitations   ClinicInvitation[]
  patients      Patient[]
  appointments  Appointment[]
  labOrders     LabOrder[]
  invoices      Invoice[]
  inventory     InventoryItem[]
  orders        Order[]
  waitingList   WaitingList[]
  expenses      Expense[]
  promotions    Promotion[]
  priceList     PriceListItem[]
  reminderLogs  ReminderLog[]
  chairs        Chair[]
  bookings      Booking[]

  @@map("clinics")
}

/// Online booking requests from public /book/:clinicId page (KazDent donor).
model Booking {
  id          String   @id @default("")
  clinicId    String
  patientName String
  phone       String
  email       String?
  doctorId    String?
  doctorName  String?
  serviceName String?
  date        DateTime @db.Date
  time        String
  notes       String?
  status      String   @default("pending")
  source      String   @default("online")

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId, status, date])
  @@map("bookings")
}

model ClinicMember {
  id                 String   @id @default("")
  userId             String
  clinicId           String
  role               UserRole @default(DOCTOR)
  /// Doctor commission % (KazDent donor: User.percent)
  commissionPercent  Int      @default(30)
  /// Fixed monthly salary (оклад) in clinic currency
  baseSalary         Float    @default(0)
  /// commission | salary | mixed
  payType            String   @default("commission")

  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now())

  @@unique([userId, clinicId])
  @@map("clinic_members")
}

model ClinicInvitation {
  id        String   @id @default("")
  clinicId  String
  email     String?
  role      UserRole @default(DOCTOR)
  code      String   @unique
  expiresAt DateTime?
  usedAt    DateTime?
  usedBy    String?

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("clinic_invitations")
}

// ─── PATIENT CRM ───

model Patient {
  id        String  @id @default("")
  clinicId  String
  firstName String
  lastName  String
  phone     String?
  email     String?
  birthDate DateTime?
  gender    String?
  address   String?
  notes     String?
  medicalHistory Json?
  /// Prepaid clinic credit (KazDent donor: Patient.balance)
  prepaidBalance Float @default(0)

  clinic      Clinic           @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  visits      Visit[]
  appointments Appointment[]
  teeth       Tooth[]
  treatmentPlans TreatmentPlan[]
  images      PatientImage[]
  documents   Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId])
  @@map("patients")
}

// ─── APPOINTMENTS ───

model Appointment {
  id        String              @id @default("")
  clinicId  String
  patientId String
  doctorId  String
  date      DateTime
  time      String?
  duration  Int?                @default(30)
  status    AppointmentStatus   @default(PENDING)
  type      String?
  notes     String?
  /// CRM extras: serviceName, servicePrice, paymentStatus, diagnosis, toothNumber, receiptId
  meta      Json?

  clinic  Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId, date])
  @@index([doctorId, date])
  @@map("appointments")
}

// ─── CRM OPS (waiting list, expenses, promotions, price list) ───

model WaitingList {
  id               String    @id @default("")
  clinicId         String
  patientId        String?
  patientName      String?
  patientPhone     String?
  doctorId         String?
  doctorName       String?
  preferredDate    DateTime?
  preferredTime    String?
  preferredService String?
  notes            String?
  status           String    @default("waiting")

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId, status])
  @@map("waiting_list")
}

model Expense {
  id          String   @id @default("")
  clinicId    String
  category    String?
  amount      Float
  description String?
  notes       String?
  date        DateTime @default(now())

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId, date])
  @@map("expenses")
}

model Promotion {
  id              String    @id @default("")
  clinicId        String
  title           String
  description     String?
  discountPercent Int?      @default(0)
  serviceIds      Json?
  startDate       DateTime?
  endDate         DateTime?
  active          Boolean   @default(true)
  imageUrl        String?

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId])
  @@map("promotions")
}

model PriceListItem {
  id          String  @id @default("")
  clinicId    String
  serviceCode String
  name        String?
  price       Float
  /// Material / consumable cost for payroll net (KazDent: mat_cost)
  matCost     Float   @default(0)
  active      Boolean @default(true)

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clinicId, serviceCode])
  @@index([clinicId])
  @@map("price_list")
}

model ReminderLog {
  id          String   @id @default("")
  clinicId    String
  reminderKey String
  channel     String?
  sentAt      DateTime @default(now())
  meta        Json?

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId, reminderKey])
  @@map("reminder_logs")
}

model Chair {
  id        String  @id @default("")
  clinicId  String
  name      String
  sortOrder Int     @default(0)
  active    Boolean @default(true)

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId, active])
  @@map("chairs")
}

// ─── MEDICAL RECORDS ───

model Visit {
  id         String  @id @default("")
  patientId  String
  doctorId   String
  date       DateTime @default(now())
  diagnosis  String?
  complaints String?
  anamnesis  String?
  treatment  Json?
  notes      String?

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@map("visits")
}

model Tooth {
  id        String @id @default("")
  patientId String
  number    Int
  condition String?
  diagnosis String?
  notes     String?

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([patientId, number])
  @@map("teeth")
}

model TreatmentPlan {
  id        String  @id @default("")
  patientId String
  title     String
  status    String  @default("draft")
  items     Json
  price     Float?
  notes     String?

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("treatment_plans")
}

model PatientImage {
  id        String    @id @default("")
  patientId String
  type      ImageType
  url       String
  name      String?
  metadata  Json?

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("patient_images")
}

model Document {
  id        String  @id @default("")
  patientId String?
  clinicId  String?
  type      String
  name      String?
  url       String
  signed    Boolean @default(false)
  signedAt  DateTime?

  patient Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@map("documents")
}

// ─── LAB ORDERS ───

model LabOrder {
  id        String   @id @default("")
  patientId String?
  clinicId  String
  labName   String?
  status    String   @default("pending")
  type      String?
  notes     String?
  files     Json?
  deadline  DateTime?
  price     Float?

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId])
  @@map("lab_orders")
}

// ─── BILLING ───

model Invoice {
  id        String        @id @default("")
  clinicId  String
  patientId String?
  amount    Float
  status    InvoiceStatus @default(UNPAID)
  items     Json
  notes     String?
  paidAt    DateTime?

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId])
  @@map("invoices")
}

// ─── INVENTORY ───

model InventoryItem {
  id       String @id @default("")
  clinicId String
  name     String
  category String?
  quantity Int    @default(0)
  minimum  Int    @default(0)
  price    Float?
  unit     String?
  supplier String?

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId])
  @@map("inventory")
}

// ─── AI CORE ───

model AISession {
  id       String @id @default("")
  userId   String
  clinicId String
  messages Json
  context  Json

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("ai_sessions")
}

model AIAction {
  id       String @id @default("")
  userId   String
  intent   String
  payload  Json
  status   String @default("pending")
  result   Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("ai_actions")
}

model AIAlert {
  id       String  @id @default("")
  userId   String
  type     String
  priority String  @default("low")
  message  String
  resolved Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, resolved])
  @@map("ai_alerts")
}

// ─── MARKETPLACE ───

// ─── ECOSYSTEM: SUPPLIERS (Phase 2) ───

enum SupplierStatus {
  PENDING
  DOCUMENTS_REVIEW
  VERIFIED
  OFFICIAL_PARTNER
  SUSPENDED
}

enum SupplierKind {
  MANUFACTURER
  DISTRIBUTOR
  SUPPLIER
  BRAND_REPRESENTATIVE
}

model Supplier {
  id            String         @id @default(uuid())
  name          String
  kind          SupplierKind   @default(SUPPLIER)
  bin           String?
  legalAddress  String?
  /// Delivery / warehouse city (Kazakhstan)
  city          String?
  contactPerson String?
  phone         String?
  email         String?
  status        SupplierStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products  Product[]
  documents SupplierDocument[]
  members   SupplierMember[]

  @@index([city])
  @@map("suppliers")
}

model SupplierMember {
  id         String   @id @default(uuid())
  userId     String
  supplierId String
  role       String   @default("owner")
  createdAt  DateTime @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([userId, supplierId])
  @@index([userId])
  @@map("supplier_members")
}

model SupplierDocument {
  id         String   @id @default(uuid())
  supplierId String
  type       String
  url        String
  verified   Boolean  @default(false)

  createdAt DateTime @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
  @@map("supplier_documents")
}

model Product {
  id          String @id @default("")
  name        String
  brand       String?
  category    String?
  price       Float
  stock       Int    @default(0)
  description String?
  imageUrl    String?
  rating      Float?
  supplierId  String?
  /// Supplier private-label / own brand — higher DentCash rate tier
  ownBrand    Boolean @default(false)

  // Rich product-card fields (Phase 2)
  manufacturer  String?
  country       String?
  expiryDate    DateTime?
  compatibility String?

  favorites Favorite[]
  supplier  Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([supplierId])
  @@map("products")
}

model Order {
  id       String @id @default("")
  clinicId String
  userId   String
  items    Json
  status   String @default("pending")
  total    Float
  /// Checkout extras: dentCashMinor spent, delivery, payment hints
  meta     Json?

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([clinicId])
  @@map("orders")
}

model Favorite {
  id        String @id @default("")
  userId    String
  productId String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@map("favorites")
}

// ─── ICD-10 ───

model ICD10Code {
  code        String @id
  description String
  category    String?

  @@map("icd10_codes")
}

// ─── SCHOOL ───

// ─── SCHOOL GOVERNANCE: LECTURERS & ACADEMIES (Phase 3) ───

enum ExpertLevel {
  NEW
  VERIFIED
  EXPERT
  INTERNATIONAL_SPEAKER
}

model Academy {
  id        String   @id @default(uuid())
  name      String
  ownerId   String?
  city      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lecturers Lecturer[]
  courses   Course[]

  @@map("academies")
}

model Lecturer {
  id        String      @id @default(uuid())
  userId    String      @unique
  level     ExpertLevel @default(NEW)
  bio       String?
  academyId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  academy       Academy?             @relation(fields: [academyId], references: [id], onDelete: SetNull)
  verifications ExpertVerification[]
  courses       Course[]

  @@index([academyId])
  @@map("lecturers")
}

model ExpertVerification {
  id         String  @id @default(uuid())
  lecturerId String
  type       String
  url        String?
  verified   Boolean @default(false)

  createdAt DateTime @default(now())

  lecturer Lecturer @relation(fields: [lecturerId], references: [id], onDelete: Cascade)

  @@index([lecturerId])
  @@map("expert_verifications")
}

model Course {
  id          String @id @default("")
  title       String
  description String?
  author      String?
  imageUrl    String?
  price       Float?
  category    String?
  duration    String?

  /// Sellable format: course | webinar | textbook | office
  format      String    @default("course")
  /// Webinar / office start time
  startsAt    DateTime?
  /// Capacity for webinar/office (null = unlimited)
  seats       Int?
  /// Textbook / materials download URL
  fileUrl     String?
  /// Extra payload (includes[], pages, venue, …)
  meta        Json?

  // Phase 3: structured authorship (gradually replaces the string `author`)
  lecturerId String?
  academyId  String?

  lessons    Lesson[]
  enrollments SchoolEnrollment[]
  lecturer   Lecturer? @relation(fields: [lecturerId], references: [id], onDelete: SetNull)
  academy    Academy?  @relation(fields: [academyId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lecturerId])
  @@index([format])
  @@map("courses")
}

model Lesson {
  id       String  @id @default("")
  courseId  String
  title    String
  videoUrl String?
  content  String?
  order    Int     @default(0)
  duration Int?

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@map("lessons")
}

model SchoolEnrollment {
  id       String @id @default("")
  userId   String
  courseId  String
  progress Int    @default(0)
  completed Boolean @default(false)
  certificateUrl String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, courseId])
  @@map("school_enrollments")
}

// ─── NOTIFICATIONS ───

model Notification {
  id       String  @id @default("")
  userId   String
  type     String
  title    String
  message  String
  read     Boolean @default(false)
  link     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, read])
  @@map("notifications")
}

// ─── AUDIT ───

model AuditLog {
  id       String @id @default("")
  userId   String?
  clinicId String?
  action   String
  entity   String?
  entityId String?
  details  Json?
  ip       String?

  createdAt DateTime @default(now())

  @@index([clinicId])
  @@map("audit_logs")
}

model AIMessage {
  id           String    @id @default("")
  sessionId    String
  role         String
  content      String
  /// Optional learning metadata (feedback loop)
  userId       String?
  clinicId     String?
  feedback     String?   // up | down
  feedbackAt   DateTime?
  prevUserText String?
  createdAt    DateTime  @default(now())

  @@index([sessionId])
  @@index([createdAt])
  @@index([userId, feedback])
  @@map("ai_messages")
}

model AIMemory {
  id        String   @id @default("")
  key       String
  value     Json
  scope     String
  userId    String
  clinicId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([key, userId, clinicId, scope])
  @@index([userId, clinicId, scope])
  @@map("ai_memories")
}

// ─── COMMUNITY ───

model CommunityPost {
  id            String   @id @default("")
  authorId      String?
  authorName    String
  authorRole    String?
  content       String
  tags          Json?
  kind          String   @default("thread")
  likesCount    Int      @default(0)
  commentsCount Int      @default(0)
  createdAt     DateTime @default(now())

  likes     CommunityLike[]
  comments  CommunityComment[]
  saves     CommunitySave[]

  @@index([createdAt])
  @@map("community_posts")
}

model CommunityLike {
  id        String   @id @default("")
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("community_likes")
}

model CommunityComment {
  id         String   @id @default("")
  postId     String
  authorId   String
  authorName String
  content    String
  createdAt  DateTime @default(now())

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@map("community_comments")
}

model CommunitySave {
  id        String   @id @default("")
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId, createdAt])
  @@map("community_saves")
}

/// 1:1 direct message thread (Instagram/Telegram-style).
model DmConversation {
  id        String   @id @default("")
  /// Sorted "userIdA:userIdB" for unique pairwise lookup
  pairKey   String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants DmParticipant[]
  messages     DmMessage[]

  @@index([updatedAt])
  @@map("dm_conversations")
}

model DmParticipant {
  id             String    @id @default("")
  conversationId String
  userId         String
  lastReadAt     DateTime?
  createdAt      DateTime  @default(now())

  conversation DmConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("dm_participants")
}

model DmMessage {
  id             String   @id @default("")
  conversationId String
  senderId       String
  body           String
  createdAt      DateTime @default(now())

  conversation DmConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("dm_messages")
}

// ─── FINANCE (Phase 4) ───

enum WalletOwnerType {
  CLINIC
  SUPPLIER
  ACADEMY
  LECTURER
  PARTNER
  PLATFORM
  GATEWAY
  USER
}

enum CashbackScope {
  ALL
  CATEGORY
  PRODUCT
  OWN_BRAND
}

enum TxStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

model Wallet {
  id        String          @id @default(uuid())
  ownerType WalletOwnerType
  ownerId   String
  currency  String          @default("KZT")
  balance   BigInt          @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  ledgerEntries LedgerEntry[]

  @@unique([ownerType, ownerId, currency])
  @@map("wallets")
}

model Transaction {
  id        String   @id @default(uuid())
  type      String
  status    TxStatus @default(COMPLETED)
  amount    BigInt
  currency  String   @default("KZT")
  refType   String?
  refId     String?
  meta      Json?
  createdAt DateTime @default(now())

  ledgerEntries LedgerEntry[]

  @@index([refType, refId])
  @@map("transactions")
}

model LedgerEntry {
  id            String @id @default(uuid())
  transactionId String
  walletId      String
  direction     String
  amount        BigInt

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  wallet      Wallet      @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([transactionId])
  @@map("ledger_entries")
}

model CommissionRule {
  id         String   @id @default(uuid())
  domain     String
  scopeId    String?
  percentBps Int
  splitJson  Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([domain, scopeId])
  @@map("commission_rules")
}

// ─── PAYMENTS (Phase 5) ───

model Payment {
  id         String   @id @default(uuid())
  provider   String   @default("kaspi_qr")
  externalId String?  @unique
  amount     BigInt
  currency   String   @default("KZT")
  status     String   @default("created")
  refType    String?
  refId      String?
  domain     String?
  sellerType String?
  sellerId   String?
  meta       Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([refType, refId])
  @@map("payments")
}

model Subscription {
  id        String          @id @default(uuid())
  ownerType WalletOwnerType
  ownerId   String
  plan      String          @default("free")
  status    String          @default("active")
  periodEnd DateTime?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([ownerType, ownerId])
  @@map("subscriptions")
}

model Payout {
  id        String   @id @default(uuid())
  walletId  String
  amount    BigInt
  status    String   @default("requested")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([walletId])
  @@map("payouts")
}

model Dispute {
  id        String   @id @default(uuid())
  refType   String
  refId     String
  reason    String
  status    String   @default("open")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([refType, refId])
  @@map("disputes")
}

// ─── DENT CASHBACK (buyer loyalty wallet) ───

model CashbackRule {
  id        String          @id @default(uuid())
  ownerType WalletOwnerType
  ownerId   String
  scope     CashbackScope   @default(ALL)
  /// Category name or product id when scope is CATEGORY / PRODUCT
  scopeKey  String?
  rateBps   Int
  capMinor  BigInt?
  active    Boolean         @default(true)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([ownerType, ownerId, active])
  @@index([scope, scopeKey])
  @@map("cashback_rules")
}

/// Human-readable DentCash history (1 DentCash = 1 ₸ = 100 тиын).
model DentCashLedger {
  id          String    @id @default(uuid())
  userId      String
  type        String
  /// pending | available | spent | reversed
  status      String    @default("pending")
  amountMinor BigInt
  currency    String    @default("KZT")
  refType     String?
  refId       String?
  sellerType  String?
  sellerId    String?
  meta        Json?
  availableAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId, status])
  @@index([refType, refId])
  @@map("dentcash_ledger")
}

// ─── COMPLIANCE (Phase 7) ───

model ComplianceCheck {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  status     String   @default("needs_review")
  findings   Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@map("compliance_checks")
}

// ─── DEVELOPER PLATFORM (Phase 8) ───

model DeveloperApp {
  id          String   @id @default(uuid())
  ownerUserId String
  name        String
  environment String   @default("sandbox")
  scopes      String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  apiKeys  ApiKey[]
  webhooks Webhook[]

  @@index([ownerUserId])
  @@map("developer_apps")
}

model ApiKey {
  id        String    @id @default(uuid())
  appId     String
  prefix    String    @unique
  hash      String
  scopes    String[]
  rateLimit Int       @default(200)
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  app DeveloperApp @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

model Webhook {
  id        String   @id @default(uuid())
  appId     String
  url       String
  events    String[]
  secret    String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  app        DeveloperApp      @relation(fields: [appId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@map("webhooks")
}

model WebhookDelivery {
  id        String   @id @default(uuid())
  webhookId String
  event     String
  payload   Json
  status    String   @default("pending")
  attempts  Int      @default(0)
  lastError String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, status])
  @@map("webhook_deliveries")
}

// ─── WORKFLOW (Phase 9) ───

model Workflow {
  id        String   @id @default(uuid())
  scopeType String   @default("CLINIC")
  scopeId   String
  name      String
  status    String   @default("active")
  trigger   Json
  graph     Json
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  runs WorkflowRun[]

  @@index([scopeType, scopeId])
  @@map("workflows")
}

model WorkflowRun {
  id          String    @id @default(uuid())
  workflowId  String
  status      String    @default("running")
  triggerData Json?
  steps       Json?
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId, status])
  @@map("workflow_runs")
}

// ─── DATA INTELLIGENCE (Phase 10) ───

model Metric {
  id         String   @id @default(uuid())
  key        String   @unique
  domain     String
  title      String
  definition Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("metrics")
}

model Dashboard {
  id        String   @id @default(uuid())
  scopeType String   @default("CLINIC")
  scopeId   String
  name      String
  layout    Json
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scopeType, scopeId])
  @@map("dashboards")
}

// ─── PARTNERS (Phase 11) ───

enum PartnerType {
  MANUFACTURER
  DISTRIBUTOR
  ACADEMY
  LABORATORY
  OFFICIAL_PARTNER
}

model Partner {
  id        String      @id @default(uuid())
  type      PartnerType
  refType   String
  refId     String
  tierId    String?
  status    String      @default("active")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  tier      PartnerTier?        @relation(fields: [tierId], references: [id], onDelete: SetNull)
  kpis      PartnerKPI[]
  slas      PartnerSLA[]
  campaigns MarketingCampaign[]

  @@index([type, status])
  @@map("partners")
}

model PartnerTier {
  id            String   @id @default(uuid())
  name          String   @unique
  commissionBps Int
  minKpiJson    Json?
  benefitsJson  Json?
  createdAt     DateTime @default(now())

  partners Partner[]

  @@map("partner_tiers")
}

model PartnerKPI {
  id          String   @id @default(uuid())
  partnerId   String
  period      String
  metricsJson Json?
  score       Float    @default(0)
  createdAt   DateTime @default(now())

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId, period])
  @@map("partner_kpis")
}

model PartnerSLA {
  id        String   @id @default(uuid())
  partnerId String
  metric    String
  target    Float
  actual    Float?
  breached  Boolean  @default(false)
  createdAt DateTime @default(now())

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId])
  @@map("partner_slas")
}

model MarketingCampaign {
  id        String    @id @default(uuid())
  partnerId String
  name      String
  budget    BigInt    @default(0)
  splitBps  Int       @default(5000)
  status    String    @default("draft")
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime  @default(now())

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@map("marketing_campaigns")
}

// ─── PROFILE & JOBS (Phase 12) ───

model JobVacancy {
  id              String   @id @default(uuid())
  title           String
  clinicName      String   @default("")
  city            String   @default("")
  salary          String   @default("")
  employmentType  String   @default("Полная занятость")
  description     String   @default("")
  tags            Json?
  status          String   @default("open")
  kind            String   @default("vacancy")

  userId   String?
  clinicId String?

  applications JobApplication[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  @@index([status, city])
  @@index([userId])
  @@map("job_vacancies")
}

model JobApplication {
  id        String   @id @default(uuid())
  vacancyId String
  userId    String

  userName  String   @default("")
  coverNote String   @default("")
  status    String   @default("new")

  vacancy JobVacancy @relation(fields: [vacancyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([vacancyId, userId])
  @@map("job_applications")
}

// ─── AI EVENT BUS ───

enum AIEventStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model AIEvent {
  id          String        @id @default(uuid())
  type        String
  source      String
  clinicId    String
  userId      String
  payload     Json
  status      AIEventStatus @default(PENDING)
  retries     Int           @default(0)
  maxRetries  Int           @default(3)
  result      Json?
  error       String?
  createdAt   DateTime      @default(now())
  processedAt DateTime?

  @@index([clinicId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@map("ai_events")
}

