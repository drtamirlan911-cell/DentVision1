DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dentvision?schema=public"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="change-me-in-production-$(openssl rand -hex 32)"
JWT_REFRESH_SECRET="change-me-refresh-$(openssl rand -hex 32)"
JWT_EXPIRES_IN="24h"
JWT_REFRESH_EXPIRES_IN="7d"
PORT=3001
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173"
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
ENCRYPTION_KEY=""

# AI / OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
OPENAI_MODEL_MINI=gpt-5.4-mini
OPENAI_MODEL_MODE=auto
OPENAI_DAILY_MINI_TOKENS=2400000
OPENAI_DAILY_FULL_TOKENS=240000
OPENAI_REASONING_EFFORT=low

# Twilio (SMS / WhatsApp notifications)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_WHATSAPP_FROM=

# Cron
CRON_SECRET=

# Platform Operations
PLATFORM_OPS_SECRET=

# Payments
KASPI_CALLBACK_SECRET=
KASPI_PAY_BASE_URL=

# Webhooks
PUBLIC_API_URL=

# Reminders
REMINDER_CRON_MS=900000
