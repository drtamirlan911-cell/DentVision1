{
  "name": "dentvision-api-server",
  "version": "1.0.0",
  "description": "Backend API server for DentVision with PostgreSQL (Neon)",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "postinstall": "prisma generate --schema ../prisma/schema.prisma && prisma db push --accept-data-loss --schema ../prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "prisma": "^6.19.3",
    "ws": "^8.21.1"
  }
}
